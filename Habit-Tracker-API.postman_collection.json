{
  "info": {
    "_postman_id": "4e5c7b98-0d64-4c66-8e4a-2b5e3f6b8f11",
    "name": "Habit Tracker API",
    "description": "Postman collection for the Habit Tracker REST API built with Express and better-sqlite3.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000"
    },
    {
      "key": "habit_id",
      "value": "1"
    },
    {
      "key": "checkin_date",
      "value": "2026-07-06"
    }
  ],
  "item": [
    {
      "name": "Create Habit",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Drink 2L water\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/habits",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "habits"
          ]
        },
        "description": "Create a new habit."
      },
      "response": []
    },
    {
      "name": "Get All Habits",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/habits",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "habits"
          ]
        },
        "description": "Get all habits with current streak values."
      },
      "response": []
    },
    {
      "name": "Check In Habit (Today)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{base_url}}/habits/{{habit_id}}/checkin",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "habits",
            "{{habit_id}}",
            "checkin"
          ]
        },
        "description": "Check in a habit for today."
      },
      "response": []
    },
    {
      "name": "Check In Habit (Specific Date)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"date\": \"{{checkin_date}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/habits/{{habit_id}}/checkin",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "habits",
            "{{habit_id}}",
            "checkin"
          ]
        },
        "description": "Check in a habit for a specific YYYY-MM-DD date."
      },
      "response": []
    },
    {
      "name": "Get Habit Checkins",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/habits/{{habit_id}}/checkins",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "habits",
            "{{habit_id}}",
            "checkins"
          ]
        },
        "description": "Get all check-in dates for one habit."
      },
      "response": []
    },
    {
      "name": "Delete One Checkin",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/habits/{{habit_id}}/checkin/{{checkin_date}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "habits",
            "{{habit_id}}",
            "checkin",
            "{{checkin_date}}"
          ]
        },
        "description": "Delete a specific check-in for a habit."
      },
      "response": []
    },
    {
      "name": "Delete Habit",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/habits/{{habit_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "habits",
            "{{habit_id}}"
          ]
        },
        "description": "Delete a habit and all of its check-ins."
      },
      "response": []
    }
  ]
}